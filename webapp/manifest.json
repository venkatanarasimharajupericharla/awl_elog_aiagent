{
	"_version": "1.60.0",
	"sap.app": {
		"id": "joule",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "AWL ELog AI Agent",
		"description": "A responsive SAPUI5 AWL ELog AI Agent that renders UI dynamically from prompts.",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"dataSources": {
			"capmService": {
				"uri": "/sales-order/",
				"type": "OData",
				"settings": {
					"odataVersion": "4.0"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"rootView": {
			"viewName": "joule.view.App",
			"type": "XML",
			"id": "app",
			"async": true
		},
		"dependencies": {
			"minUI5Version": "1.120.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.ui.layout": {},
				"sap.f": {}
			}
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "joule.i18n.i18n"
				}
			}
		},
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		}
	}
}
